# =============================================================================
# Mbody — environment variables template
# Copy to `.env.local` for local development:
#   cp .env.example .env.local
#
# Environments: development | staging | production
# Staging: push to `staging` branch → Vercel (root directory: mbody/)
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public site URL (no trailing slash). Used for metadata, auth redirects, emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# development | staging | production
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# true = use in-repo mock data (shop, cart, auth). Set false on staging/prod once Supabase is wired.
NEXT_PUBLIC_USE_MOCK_DATA=true

# Coming soon gate — set true on Vercel staging/prod until launch (omit or false for local full site)
NEXT_PUBLIC_COMING_SOON=true
# ISO 8601 launch datetime (default ~40 days). Store opens automatically after this time.
NEXT_PUBLIC_LAUNCH_AT=2026-08-09T16:00:00.000Z

# -----------------------------------------------------------------------------
# Supabase (EU region — create separate projects for dev / staging / prod)
# https://supabase.com/dashboard
# Setup guide: docs/supabase-setup.md
# Check:  pnpm check:supabase  →  GET /api/dev/supabase-config (dev only)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Or use Supabase dashboard name (same key):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — never expose to the client or commit real values
SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Init script: ../database/mbody_init.sql (run once in SQL Editor or via run-init.sh)

# -----------------------------------------------------------------------------
# Auth (Supabase)
# -----------------------------------------------------------------------------
# Comma-separated redirect URLs allowed after sign-in (configure matching URLs in Supabase Auth settings)
# NEXT_PUBLIC_AUTH_REDIRECT_URLS=http://localhost:3000/**,https://staging.example.com/**

# -----------------------------------------------------------------------------
# Payments (Phase 4 — blocked until client returns intake form)
# Intake: client-deliverables/Mbody-Payment-Provider-Credentials.md
# Docs: mbody/docs/payment-provider.md
# Check: pnpm check:payment
# -----------------------------------------------------------------------------

# stripe | swedish_bank | tbd (default until client decides)
# PAYMENT_PROVIDER=tbd

# --- Stripe (if PAYMENT_PROVIDER=stripe) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Swedish bank / generic PSP (if PAYMENT_PROVIDER=swedish_bank) ---
# PAYMENT_GATEWAY_API_URL=https://...
# PAYMENT_GATEWAY_MERCHANT_ID=
# PAYMENT_GATEWAY_API_KEY=
# PAYMENT_GATEWAY_WEBHOOK_SECRET=
# NEXT_PUBLIC_PAYMENT_GATEWAY_PUBLIC_KEY=

# --- Klarna (EU — Pay now + Pay in 30 days) ---
# KLARNA_USERNAME=
# KLARNA_PASSWORD=
# KLARNA_API_URL=https://api.playground.klarna.com

# Optional shared secret for POST /api/webhooks/payment (production)
# PAYMENT_WEBHOOK_SECRET=

# Arabic setup guide (p3-9 email + p4-0 payment): docs/ar-email-and-payments.md

# -----------------------------------------------------------------------------
# Analytics & marketing (consent-gated — future)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# Email — order confirmation (Phase 3 template · Phase 4 trigger on payment.succeeded)
# -----------------------------------------------------------------------------
# log = console preview (default dev) · resend = send via Resend API
# EMAIL_PROVIDER=log
# EMAIL_FROM=Mbody <orders@mbody.com>
# RESEND_API_KEY=

# Arabic setup guide: docs/ar-email-and-payments.md (Part 1 — order confirmation)

# Newsletter ESP (future)
# KLAVIYO_PRIVATE_API_KEY=
# KLAVIYO_PUBLIC_API_KEY=

# -----------------------------------------------------------------------------
# Build / tooling (optional local overrides)
# -----------------------------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Vercel (dashboard — Project Settings → Environment Variables)
# -----------------------------------------------------------------------------
# Root directory: mbody
# Staging: connect branch `staging` · Production: branch `main`
# After first deploy, set NEXT_PUBLIC_APP_URL to your Vercel URL, e.g.:
#   https://mbody-staging.vercel.app
