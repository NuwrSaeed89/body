# =============================================================================
# Mbody — environment variables template
# Copy to `.env.local` for local development:
#   cp .env.example .env.local
#
# Environments: development | staging | production
# Staging: push to `staging` branch → Render (see render.yaml)
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public site URL (no trailing slash). Used for metadata, auth redirects, emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# development | staging | production
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# true = use in-repo mock data (shop, cart, auth). Set false on staging/prod once Supabase is wired.
NEXT_PUBLIC_USE_MOCK_DATA=true

# -----------------------------------------------------------------------------
# Supabase (EU region — create separate projects for dev / staging / prod)
# https://supabase.com/dashboard
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client or commit real values
SUPABASE_SERVICE_ROLE_KEY=

# Optional — for `database/run-init.sh` (Project Settings → Database → Connection string)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
# Init script: ../database/mbody_init.sql (run once in SQL Editor or via run-init.sh)

# -----------------------------------------------------------------------------
# Auth (Supabase)
# -----------------------------------------------------------------------------
# Comma-separated redirect URLs allowed after sign-in (configure matching URLs in Supabase Auth settings)
# NEXT_PUBLIC_AUTH_REDIRECT_URLS=http://localhost:3000/**,https://staging.example.com/**

# -----------------------------------------------------------------------------
# Payments (future — sandbox keys on staging only)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# KLARNA_USERNAME=
# KLARNA_PASSWORD=
# KLARNA_API_URL=https://api.playground.klarna.com

# -----------------------------------------------------------------------------
# Analytics & marketing (consent-gated — future)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# -----------------------------------------------------------------------------
# Email / ESP (future)
# -----------------------------------------------------------------------------
# KLAVIYO_PRIVATE_API_KEY=
# KLAVIYO_PUBLIC_API_KEY=

# -----------------------------------------------------------------------------
# Build / tooling (optional local overrides)
# -----------------------------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Render (dashboard — do NOT put deploy hooks in .env.local)
# -----------------------------------------------------------------------------
# Staging: connect repo branch `staging` → Web Service (Frankfurt / EU)
# Production: branch `main` — see render.yaml
# After first deploy, set NEXT_PUBLIC_APP_URL to your Render URL, e.g.:
#   https://mbody-staging.onrender.com
#
# Optional — GitHub secret to trigger deploy after CI passes (disable auto-deploy on Render):
# RENDER_DEPLOY_HOOK_URL=   # Render → Service → Settings → Deploy Hook
